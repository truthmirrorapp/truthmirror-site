# ============================================================
# TruthMirror site - .gitattributes
# Normalize line endings: ALL text = LF in repo,
# checkout LF on every OS (including Windows). Binaries protected.
# ============================================================

* text=auto eol=lf

*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.svg   text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf

*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.eot   binary
*.pdf   binary
*.zip   binary
